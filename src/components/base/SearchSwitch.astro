---

---

<button
  class="inline-flex items-center text-foreground cursor-pointer hover:scale-105 size-6 origin-center"
  id="search-switch"
  type="button"
  aria-label="Search"
  aria-controls="search-mask"
  aria-expanded="false"
  title="Search (Ctrl+K)"
>
  <span class="icon-[material-symbols--manage-search] size-6"></span>
</button>

<div
  id="search-mask"
  class="fixed z-overlay hidden inset-0 bg-background/80 backdrop-blur-md dark:bg-background/90 transition-opacity duration-200 opacity-0"
  role="dialog"
  aria-modal="true"
  aria-label="Search"
>
  <div class="absolute left-1/2 top-20 -translate-x-1/2 transition-transform duration-300 -translate-y-4 search-panel-show">
    <div
      id="search-panel"
      class="grid grid-rows-[auto_1fr] max-h-[80vh] w-[22rem] sm:w-[40rem] bg-background/95 dark:bg-background/95 border border-border shadow-lg dark:shadow-accent/20 overflow-hidden"
    >
      <div id="search-bar" class="grid grid-cols-[auto_1fr_auto_auto] items-center gap-2 px-4 h-12 border-b border-border">
        <span class="icon-[material-symbols--manage-search] size-6 text-muted-foreground"></span>
        <label class="sr-only" for="search-input">Search</label>
        <input
          type="search"
          id="search-input"
          class="w-full h-8 bg-transparent outline-none text-foreground placeholder:text-muted-foreground font-normal leading-8 text-base"
          placeholder="Search"
          autocomplete="off"
        />
        <button
          id="search-exact"
          type="button"
          class="inline-flex items-center gap-1 px-2 py-0.5 text-xs rounded border border-border text-muted-foreground hover:bg-accent select-none"
          aria-pressed="false"
          title="Exact Match"
        >
          Exact
        </button>
        <kbd class="hidden sm:inline-flex items-center gap-1 px-2 py-0.5 text-xs text-muted-foreground bg-muted rounded">ESC</kbd>
      </div>
      <div id="search-results" class="overflow-y-auto no-scrollbar p-1 sm:p-2 overscroll-contain" data-base="/"></div>
    </div>
  </div>
</div>

<script>
  declare const pagefind: {
    debouncedSearch: (query: string) => Promise<{
      results?: Array<{
        data: () => Promise<{
          url: string
          excerpt: string
          meta: { title: string }
          sub_results?: Array<{ url: string; title: string; excerpt: string }>
        }>
      }>
    } | null>
  }

  // Module-scope state survives SPA navigations.
  let exactMode = readExactMode()
  let searchReqId = 0
  let setupController: AbortController | null = null
  let lastFocusedElement: HTMLElement | null = null
  // pagefind 懒加载:只在用户首次触发搜索时才下载 pagefind bundle。
  let pagefindReadyPromise: Promise<void> | null = null

  async function ensurePagefindReady() {
    if (!import.meta.env.PROD) return
    if (pagefindReadyPromise) return pagefindReadyPromise
    pagefindReadyPromise = (async () => {
      if ((window as any).pagefind) return
      // /pagefind/pagefind.js 是构建产物，不走 Vite import 解析，用字符串字面量拼接绕过静态分析。
      const mod = await import(/* @vite-ignore */ '/pagefind/pagefind.js'.toString())
      await mod.options({ excerptLength: 20, showSubResults: true })
      mod.init()
      ;(window as any).pagefind = mod
    })().catch((err) => {
      pagefindReadyPromise = null
      throw err
    })
    return pagefindReadyPromise
  }

  function readExactMode(): boolean {
    try {
      return localStorage.getItem('search-exact') === '1'
    } catch {
      return false
    }
  }

  function writeExactMode(value: boolean) {
    try {
      localStorage.setItem('search-exact', value ? '1' : '0')
    } catch {
      /* private browsing — ignore */
    }
  }

  function unlockBodyScroll() {
    document.body.style.overflow = ''
    document.body.style.paddingRight = ''
  }

  function teardown() {
    setupController?.abort()
    setupController = null
    // Defensive: SPA nav while modal open must not leave body locked.
    unlockBodyScroll()
  }

  function setup() {
    teardown()
    const controller = new AbortController()
    setupController = controller
    const { signal } = controller

    const searchInput = document.getElementById('search-input') as HTMLInputElement | null
    const searchMask = document.getElementById('search-mask')
    const searchSwitch = document.getElementById('search-switch')
    const searchResults = document.getElementById('search-results')
    const exactToggle = document.getElementById('search-exact') as HTMLButtonElement | null

    if (!searchInput || !searchMask || !searchSwitch || !searchResults) return

    function updateExactUI() {
      if (!exactToggle) return
      exactToggle.setAttribute('aria-pressed', exactMode ? 'true' : 'false')
      exactToggle.classList.toggle('bg-accent', exactMode)
      exactToggle.classList.toggle('text-muted-foreground', !exactMode)
    }
    updateExactUI()

    function openSearch() {
      lastFocusedElement = (document.activeElement as HTMLElement | null) ?? null
      searchMask!.classList.remove('hidden')
      void searchMask!.offsetHeight
      searchMask!.classList.remove('opacity-0')
      searchSwitch!.setAttribute('aria-expanded', 'true')
      searchInput!.focus()
      // paddingRight 抵消滚动条消失带来的横向跳动，与 PhotoGalleryModal 保持一致。
      const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth
      document.body.style.overflow = 'hidden'
      document.body.style.paddingRight = `${scrollbarWidth}px`
      // 首次打开时触发 pagefind 下载/初始化；后续 handleInput 会 await 同一个 promise。
      void ensurePagefindReady().catch(() => {})
    }

    function closeSearch(immediate = false) {
      searchMask!.classList.add('opacity-0')
      searchSwitch!.setAttribute('aria-expanded', 'false')
      searchInput!.value = ''
      searchResults!.innerHTML = ''
      const finalize = () => {
        searchMask!.classList.add('hidden')
        unlockBodyScroll()
        // Restore focus to whatever had it before the modal opened, falling back to the trigger.
        if (lastFocusedElement && document.contains(lastFocusedElement)) {
          lastFocusedElement.focus()
        } else {
          searchSwitch!.focus()
        }
        lastFocusedElement = null
      }
      if (immediate) {
        finalize()
      } else {
        setTimeout(finalize, 200)
      }
    }

    exactToggle?.addEventListener(
      'click',
      () => {
        exactMode = !exactMode
        writeExactMode(exactMode)
        updateExactUI()
        searchInput.dispatchEvent(new Event('input'))
      },
      { signal }
    )

    searchSwitch.addEventListener('click', openSearch, { signal })

    searchMask.addEventListener(
      'click',
      (e) => {
        if (e.target === searchMask) closeSearch()
      },
      { signal }
    )

    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape') closeSearch()
        if (e.ctrlKey && e.key.toLowerCase() === 'k') {
          e.preventDefault()
          if (searchMask.classList.contains('hidden')) {
            openSearch()
          } else {
            closeSearch()
          }
        }
      },
      { signal }
    )

    function renderMessage(iconClass: string, text: string) {
      const wrapper = document.createElement('div')
      wrapper.className = 'search-results-item py-8'
      const inner = document.createElement('div')
      inner.className = 'flex items-center justify-center gap-2 select-none'
      const icon = document.createElement('span')
      icon.className = `${iconClass} size-5 text-muted-foreground`
      const label = document.createElement('span')
      label.className = 'text-muted-foreground'
      label.textContent = text
      inner.appendChild(icon)
      inner.appendChild(label)
      wrapper.appendChild(inner)
      return wrapper
    }

    function renderResultItem(url: string, title: string, excerpt: string, modifier = '') {
      const item = document.createElement('a')
      item.href = url
      item.className = modifier ? `search-results-item ${modifier}` : 'search-results-item'

      // textContent is safe: title may contain arbitrary markdown characters.
      const titleEl = document.createElement('div')
      titleEl.className = modifier ? 'search-results-title text-sm opacity-80' : 'search-results-title'
      titleEl.textContent = title

      // Pagefind excerpts intentionally include <mark> highlights; keep as HTML.
      const excerptEl = document.createElement('div')
      excerptEl.className = modifier ? 'search-results-excerpt text-xs' : 'search-results-excerpt'
      excerptEl.innerHTML = excerpt

      item.appendChild(titleEl)
      item.appendChild(excerptEl)
      item.addEventListener('click', () => closeSearch(true), { signal })
      return item
    }

    async function handleInput(e: Event) {
      searchResults!.innerHTML = ''
      const target = e.target as HTMLInputElement
      const q = target.value.trim()
      const reqId = ++searchReqId

      if (q === '') {
        searchResults!.appendChild(renderMessage('icon-[material-symbols--keyboard]', 'Type to search'))
        return
      }

      if (!import.meta.env.PROD) {
        searchResults!.appendChild(renderMessage('icon-[material-symbols--help-outline]', 'No results in development mode'))
        return
      }

      // 搜索首次触发时可能还在等 pagefind 下载；await 保证 module 就绪后再查询。
      await ensurePagefindReady()
      const currentPagefind = (window as any).pagefind as typeof pagefind | undefined
      if (!currentPagefind) {
        searchResults!.appendChild(renderMessage('icon-[material-symbols--help-outline]', 'Search index unavailable'))
        return
      }
      const pagefindQuery = exactMode ? `"${q}"` : q
      const search = await currentPagefind.debouncedSearch(pagefindQuery)

      // Drop stale results from superseded requests.
      if (reqId !== searchReqId || searchInput!.value.trim() !== q) return

      if (!search?.results || search.results.length === 0) {
        searchResults!.appendChild(renderMessage('icon-[material-symbols--help-outline]', 'No results found'))
        return
      }

      for (const result of search.results) {
        const data = await result.data()
        searchResults!.appendChild(renderResultItem(data.url, data.meta.title, data.excerpt))

        if (data.sub_results) {
          for (const subResult of data.sub_results) {
            if (subResult.excerpt === data.excerpt) continue
            const cleanTitle = subResult.title.replace(/\s*[Hh][1-6]$/g, '')
            if (!cleanTitle) continue
            searchResults!.appendChild(
              renderResultItem(subResult.url, cleanTitle, subResult.excerpt, 'sub-result pl-4 border-l-2 border-accent')
            )
          }
        }
      }
    }

    searchInput.addEventListener('input', handleInput, { signal })
  }

  if (document.readyState !== 'loading') {
    setup()
  } else {
    document.addEventListener('DOMContentLoaded', setup)
  }

  document.addEventListener('astro:page-load', setup)
  document.addEventListener('astro:before-preparation', teardown)
</script>
