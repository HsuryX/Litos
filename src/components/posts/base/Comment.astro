---
import { COMMENT_CONFIG, POSTS_CONFIG } from '~/config'
import Giscus from './Giscus.astro'

interface Props {
  id: string
  title: string
}

const { id, title } = Astro.props
const { enabled, system, giscus } = COMMENT_CONFIG

const isGiscusConfigured =
  system === 'giscus' && giscus && !giscus.repoId.startsWith('REPLACE_') && !giscus.categoryId.startsWith('REPLACE_')

if (!enabled || system === 'none' || (system === 'giscus' && !isGiscusConfigured)) {
  return null
}
---

<div class="comment-container">
  <h3 class="text-xl font-semibold mb-6 text-[var(--color-heading)]">{POSTS_CONFIG.commentsText}</h3>

  {system === 'giscus' && <Giscus id={id} title={title} />}
</div>
